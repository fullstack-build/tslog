{
  "name": "tslog",
  "version": "4.10.2",
  "description": "Extensible TypeScript Logger for Node.js and Browser.",
  "author": "Eugene <opensource@terehov.de> (https://fullstack.build)",
  "license": "MIT",
  "funding": "https://github.com/fullstack-build/tslog?sponsor=1",
  "homepage": "https://tslog.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fullstack-build/tslog.git"
  },
  "bugs": {
    "url": "https://github.com/fullstack-build/tslog/issues"
  },
  "type": "module",
  "module": "./dist/esm/index.universal.js",
  "types": "./dist/types/index.d.ts",
  "browser": {
    "tslog": "./dist/browser/index.js",
    "util": false
  },
  "react-native": "./dist/esm/index.universal.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/esm/index.browser.js",
      "worker": "./dist/esm/index.browser.js",
      "deno": "./dist/esm/index.universal.js",
      "bun": "./dist/esm/index.universal.js",
      "node": "./dist/esm/index.node.js",
      "react-native": "./dist/esm/index.universal.js",
      "default": "./dist/esm/index.universal.js"
    },
    "./transports/file": {
      "types": "./dist/types/subpaths/transports/file.d.ts",
      "node": "./dist/esm/subpaths/transports/file.js",
      "default": "./dist/esm/subpaths/transports/file.js"
    },
    "./transports/http": {
      "types": "./dist/types/subpaths/transports/http.d.ts",
      "default": "./dist/esm/subpaths/transports/http.js"
    },
    "./transports/ringbuffer": {
      "types": "./dist/types/subpaths/transports/ringBuffer.d.ts",
      "default": "./dist/esm/subpaths/transports/ringBuffer.js"
    },
    "./transports/worker": {
      "types": "./dist/types/subpaths/transports/worker.d.ts",
      "node": "./dist/esm/subpaths/transports/worker.js",
      "default": "./dist/esm/subpaths/transports/worker.js"
    },
    "./presets/pino": {
      "types": "./dist/types/subpaths/presets/pino.d.ts",
      "default": "./dist/esm/subpaths/presets/pino.js"
    },
    "./otel": {
      "types": "./dist/types/subpaths/presets/otel.d.ts",
      "default": "./dist/esm/subpaths/presets/otel.js"
    },
    "./presets/genai": {
      "types": "./dist/types/subpaths/presets/genai.d.ts",
      "default": "./dist/esm/subpaths/presets/genai.js"
    },
    "./serializers": {
      "types": "./dist/types/subpaths/serializers/std.d.ts",
      "default": "./dist/esm/subpaths/serializers/std.js"
    },
    "./lite": {
      "types": "./dist/types/subpaths/lite.d.ts",
      "default": "./dist/esm/subpaths/lite.js"
    },
    "./slim": {
      "types": "./dist/types/subpaths/slim.d.ts",
      "default": "./dist/esm/subpaths/slim.js"
    },
    "./console": {
      "types": "./dist/types/subpaths/wrapConsole.d.ts",
      "default": "./dist/esm/subpaths/wrapConsole.js"
    },
    "./testing": {
      "types": "./dist/types/subpaths/testing.d.ts",
      "default": "./dist/esm/subpaths/testing.js"
    },
    "./pretty/box": {
      "types": "./dist/types/subpaths/pretty/box.d.ts",
      "default": "./dist/esm/subpaths/pretty/box.js"
    },
    "./throttle": {
      "types": "./dist/types/subpaths/throttle.d.ts",
      "default": "./dist/esm/subpaths/throttle.js"
    },
    "./cli": {
      "types": "./dist/types/subpaths/cli.d.ts",
      "node": "./dist/esm/subpaths/cli.js",
      "default": "./dist/esm/subpaths/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "tslog": "./dist/esm/subpaths/cli.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "npm run build-types && npm run build-esm && npm run build-browser && npm run prepare-publish",
    "build-browser": "node build.js",
    "build-types": "tsgo -p tsconfig.types.json",
    "build-esm": "tsgo -p tsconfig.esm.json",
    "build-example": "tsgo -p tsconfig.example.json",
    "audit-sideeffects": "node scripts/audit-sideeffects.mjs",
    "bench": "node benchmarks/bench.mjs",
    "dev-ts": "nodemon examples/server/index2.ts",
    "dev-ts-old-example": "nodemon examples/server/index.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write . && npm run check-doc-sync",
    "check-doc-sync": "node scripts/check-doc-sync.mjs",
    "test": "vitest run",
    "test:browser": "npx playwright test",
    "test:bun": "bunx vitest run",
    "test:deno": "npm run build && deno test --allow-read --allow-env tests/deno_runner.ts",
    "test:all": "vitest run && npx playwright test",
    "test-browser-serve": "npm run build-browser && node tests/support/browser/server/index.cjs -p 4444",
    "coverage": "vitest run --coverage",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview",
    "pre-publish": "npm run build",
    "release": "np --any-branch",
    "pre-commit-hook": "bash ./scripts/pre-commit.sh",
    "prepare-publish": "node scripts/prepare-publish.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "npm run sync-version"
  },
  "engines": {
    "node": ">=20"
  },
  "np": {
    "yarn": false,
    "contents": "./dist"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "nodemonConfig": {
    "watch": [
      "./**/*.ts"
    ],
    "exec": "node --experimental-specifier-resolution=node --enable-source-maps --no-warnings --loader ts-node/esm"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.0.0",
    "bson": "^6.10.4",
    "esbuild": "^0.25.10",
    "graphql": "^16.14.2",
    "husky": "^9.1.7",
    "nodemon": "^3.1.10",
    "np": "^11.0.2",
    "playwright": "^1.50.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260629.1",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "tmp": "^0.2.5"
  },
  "sideEffects": false,
  "keywords": [
    "logger",
    "typescript",
    "log level",
    "json",
    "stacktrace",
    "Error.stack",
    "call location",
    "debug",
    "pretty",
    "log",
    "log4j",
    "log4js",
    "log4ts",
    "print",
    "logging",
    "stack",
    "trace",
    "pretty print",
    "prettify",
    "format",
    "human",
    "callsites",
    "callsite",
    "show error",
    "handling exceptions",
    "pretty log",
    "pretty json",
    "pretty-error",
    "sourcemap"
  ]
}
